# Edge único no VPS — Caddy na 80/443, cada stack nginx só em localhost (HTTP).
#
# Pré-requisitos em /opt/ibigan/.env e /opt/nagibi/.env:
#   NGINX_BEHIND_PROXY=true
#   ibigan:  NGINX_HTTP_PORT=18080  MYSQL_HOST_PORT=3307
#   nagibi:  NGINX_HTTP_PORT=28080  MYSQL_HOST_PORT=3306
#
#   caddy validate --config /etc/caddy/Caddyfile
#   systemctl reload caddy

ibigan.com.br {
	reverse_proxy http://127.0.0.1:18080 {
		header_up Host {host}
		header_up X-Forwarded-Proto https
	}
}

www.ibigan.com.br {
	redir https://ibigan.com.br{uri} permanent
}

nagibi.com.br {
	reverse_proxy http://127.0.0.1:28080 {
		header_up Host {host}
		header_up X-Forwarded-Proto https
	}
}

www.nagibi.com.br {
	redir https://nagibi.com.br{uri} permanent
}
