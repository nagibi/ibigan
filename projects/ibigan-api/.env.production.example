# ═══════════════════════════════════════════════════════════════
# Ibigan — produção (Laravel API)
# Copiar para: /opt/ibigan/projects/ibigan-api/.env
# Arquivo REAL (não symlink). Docker Compose usa /opt/ibigan/.env à parte.
# ═══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
APP_NAME=Ibigan
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ibigan.com.br
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR

API_RATE_LIMIT_PER_MINUTE=600

LOG_CHANNEL=stack
LOG_LEVEL=warning

# ── Database (credenciais = /opt/ibigan/.env MYSQL_*) ───────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ibigan_central
DB_USERNAME=ibigan
DB_PASSWORD=

# ── Redis ──────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=ibigan_

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ── Mail (Brevo / SMTP) ────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@ibigan.com.br
MAIL_FROM_NAME="${APP_NAME}"

# ── Branding de e-mails (relatórios, convites, reset senha) ───
EMAIL_BRAND_NAME=Ibigan
EMAIL_LOGO_URL=https://ibigan.com.br/images/email/ibigan-logo.png

# ── Broadcast / Reverb ─────────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=

# Laravel → Reverb (rede interna Docker)
REVERB_BROADCAST_HOST=reverb
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http

# Browser / frontend (wss em produção)
REVERB_PUBLIC_HOST=ibigan.com.br
REVERB_PUBLIC_PORT=443
REVERB_PUBLIC_SCHEME=https

# ── Frontend / multi-tenant ────────────────────────────────────
FRONTEND_URL=https://ibigan.com.br
# Somente hostname (sem https://)
CENTRAL_DOMAIN=ibigan.com.br
TENANT_DEV_DOMAIN_SUFFIXES=ibigan.com.br
TENANT_CONTEXT_QUERY_PARAM=tenant

# ── OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://ibigan.com.br/api/v1/auth/google/callback

# ── Scout / Meilisearch ────────────────────────────────────────
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# ── Ferramentas (painel central — URLs públicas) ───────────────
DEV_TOOLS_API_DOCS_URL=https://ibigan.com.br/docs/api
DEV_TOOLS_HORIZON_URL=https://ibigan.com.br/horizon
DEV_TOOLS_TELESCOPE_URL=https://ibigan.com.br/telescope
DEV_TOOLS_CLOCKWORK_URL=https://ibigan.com.br/clockwork
DEV_TOOLS_LOG_VIEWER_URL=https://ibigan.com.br/log-viewer

# ── Observabilidade ────────────────────────────────────────────
TELESCOPE_ENABLED=true
TELESCOPE_RECORD_ALL=true
CLOCKWORK_ENABLE=true
LOG_VIEWER_ENABLED=true

PROMETHEUS_ENABLED=true
METRICS_TOKEN=

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

FILESYSTEM_DISK=local

# ═══════════════════════════════════════════════════════════════
# NÃO coloque VITE_* aqui — pertencem ao build do frontend:
#   projects/ibigan-web/.env.production (ou variáveis no npm run build)
#
# VITE_REVERB_APP_KEY=<mesmo REVERB_APP_KEY>
# VITE_REVERB_HOST=ibigan.com.br
# VITE_REVERB_PORT=443
# VITE_REVERB_SCHEME=https
# VITE_SENTRY_DSN=<opcional, DSN do projeto React>
# ═══════════════════════════════════════════════════════════════
