APP_NAME=Ibigan
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Sao_Paulo

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── MySQL (Docker: serviço mysql) ─────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ibigan_central
DB_USERNAME=dev
DB_PASSWORD=dev

# ── Redis ───────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=ibigan_

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
# SESSION_DRIVER=database + SESSION_CONNECTION=central → sessões na tabela central.sessions
# SESSION_DRIVER=redis → não definir SESSION_CONNECTION (usa redis "default")
# SESSION_CONNECTION=central
SESSION_LIFETIME=120

# ── Broadcast / Reverb ──────────────────────────────────────
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=ibigan
REVERB_APP_KEY=ibigan_key
REVERB_APP_SECRET=ibigan_secret

# Laravel → Reverb (rede interna Docker)
REVERB_BROADCAST_HOST=reverb
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http

# Browser / Vite (host) — deve coincidir com ibigan-web/.env.local
REVERB_PUBLIC_HOST=localhost
REVERB_PUBLIC_PORT=8082
REVERB_PUBLIC_SCHEME=http

# ── Mail (Mailpit local) ─────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@ibigan.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── Scout / Meilisearch ─────────────────────────────────────
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=masterKey

# ── Frontend ────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# Google OAuth (criar credenciais em console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# Apple Sign In (opcional)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost/api/v1/auth/apple/callback

# ── Ferramentas dev ─────────────────────────────────────────
DEV_TOOLS_API_DOCS_URL=http://localhost/docs/api
DEV_TOOLS_HORIZON_URL=http://localhost/horizon
DEV_TOOLS_TELESCOPE_URL=http://localhost/telescope
DEV_TOOLS_CLOCKWORK_URL=http://localhost/clockwork
DEV_TOOLS_LOG_VIEWER_URL=http://localhost/log-viewer

# ── Observabilidade ─────────────────────────────────────────
# Em produção (APP_DEBUG=false), Clockwork exige CLOCKWORK_ENABLE=true.
CLOCKWORK_ENABLE=true
# CLOCKWORK_ENABLE=null → ativo quando APP_DEBUG=true (somente local/dev)
LOG_VIEWER_ENABLED=true
PROMETHEUS_ENABLED=false
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.2

FILESYSTEM_DISK=local
