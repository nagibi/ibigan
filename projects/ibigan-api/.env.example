APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_CONNECTION=central
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# Laravel Scout — busca global (Menu, User). Reindexar: php artisan tenants:run search:reindex
# collection = dev/test sem Meilisearch; meilisearch = produção/docker
SCOUT_DRIVER=collection
# SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://localhost:7700
# MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

# Prometheus — endpoint central /metrics (não por tenant)
PROMETHEUS_ENABLED=false
# PROMETHEUS_ENABLED=true
# METRICS_TOKEN=ibigan_metrics_dev
# PROMETHEUS_TRACES_SAMPLE_RATE via SENTRY; scrape interval no prometheus.yml
# PROMETHEUS_ALLOWED_IPS=  # opcional, além do token

# Sentry (deixe vazio em dev local se não usar)
SENTRY_LARAVEL_DSN=
# SENTRY_LARAVEL_DSN=https://xxxx@oyyy.ingest.sentry.io/zzz
SENTRY_ENVIRONMENT=local
SENTRY_TRACES_SAMPLE_RATE=0.2
# SENTRY_SEND_DEFAULT_PII=false

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@ibigan.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

FRONTEND_URL=http://localhost:5173

# URLs das ferramentas de admin (docs, Horizon). Em PRD use APP_URL ou defina explicitamente.
# DEV_TOOLS_API_DOCS_URL=https://nagibi.com.br/docs/api
# DEV_TOOLS_HORIZON_URL=https://nagibi.com.br/horizon

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Alias legado (opcional — prefira GOOGLE_CLIENT_SECRET)
GOOGLE_SECRET=
GOOGLE_REDIRECT_URI=http://localhost/api/v1/auth/google/callback

# Apple Sign In (iCloud)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
APPLE_REDIRECT_URI=http://localhost/api/v1/auth/apple/callback
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Private key contents (use \n for line breaks) or leave empty if using APPLE_CLIENT_SECRET
APPLE_PRIVATE_KEY=
