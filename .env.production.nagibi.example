# Copiar para /opt/nagibi/.env
# Clone do mesmo repositório/arquitetura com STACK_NAME e portas distintos.

STACK_NAME=nagibi

APP_NAME=Nagibi
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://nagibi.com.br
APP_TIMEZONE=America/Sao_Paulo

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nagibi_central
DB_USERNAME=nagibi
DB_PASSWORD=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=nagibi_

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_BROADCAST_HOST=reverb
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http
REVERB_PUBLIC_HOST=nagibi.com.br
REVERB_PUBLIC_PORT=443
REVERB_PUBLIC_SCHEME=https

MAIL_FROM_ADDRESS=no-reply@nagibi.com.br
MAIL_FROM_NAME=Nagibi

FRONTEND_URL=https://nagibi.com.br
CENTRAL_DOMAIN=nagibi.com.br
TENANT_DEV_DOMAIN_SUFFIXES=nagibi.com.br

# MySQL no host: 3307 para não colidir com ibigan (3306)
MYSQL_HOST_PORT=3307
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=nagibi_central
MYSQL_USER=nagibi
MYSQL_PASSWORD=

# Stack edge (único com 80/443 públicos no VPS):
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Se ibigan for o edge, use localhost aqui e Caddy no host (docker/host-proxy/Caddyfile.example):
# NGINX_HTTP_BIND=127.0.0.1
# NGINX_HTTP_PORT=28080
# NGINX_HTTPS_BIND=127.0.0.1
# NGINX_HTTPS_PORT=28443
