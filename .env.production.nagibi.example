# Copiar para /opt/nagibi/.env — SOMENTE variáveis do Docker Compose.
# Laravel (APP_KEY, DB_*, Reverb, mail…) fica em projects/ibigan-api/.env (arquivo separado).

STACK_NAME=nagibi
APP_TIMEZONE=America/Sao_Paulo
CENTRAL_DOMAIN=nagibi.com.br
REDIS_PREFIX=nagibi_

NGINX_BEHIND_PROXY=true
NGINX_HTTP_BIND=127.0.0.1
NGINX_HTTP_PORT=28080

MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=nagibi_central
MYSQL_USER=nagibi
MYSQL_PASSWORD=

# ── Laravel: /opt/nagibi/projects/ibigan-api/.env (NÃO symlink, NÃO copiar da raiz) ──
# APP_KEY=base64:...
# DB_PASSWORD= (igual a MYSQL_PASSWORD acima)
# DB_USERNAME=nagibi
# DB_DATABASE=nagibi_central
# APP_URL=https://nagibi.com.br
# FRONTEND_URL, REVERB_*, MAIL_*, GOOGLE_*, etc.
