# Copiar para /opt/ibigan/.env no servidor Vultr (216.238.124.52)
# Domínio: nagibi.com.br

APP_NAME=Ibigan
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://nagibi.com.br
APP_TIMEZONE=America/Sao_Paulo

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ibigan_central
DB_USERNAME=ibigan
DB_PASSWORD=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=ibigan_

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=central

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_BROADCAST_HOST=reverb
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http
REVERB_PUBLIC_HOST=nagibi.com.br
REVERB_PUBLIC_PORT=443
REVERB_PUBLIC_SCHEME=https

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@nagibi.com.br
MAIL_FROM_NAME=Ibigan

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

FRONTEND_URL=https://nagibi.com.br

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production

# Docker Compose (docker-compose.prod.yml)
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=ibigan_central
MYSQL_USER=ibigan
MYSQL_PASSWORD=
