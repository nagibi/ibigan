# Copiar para /opt/<stack>/.env no servidor (ex.: /opt/ibigan/.env ou /opt/nagibi/.env)
# Ajuste STACK_NAME, domínio e portas — no mesmo VPS cada stack precisa de valores distintos.

# ── Identidade do stack (evita conflito de container_name e volumes) ──
STACK_NAME=ibigan

# ── Domínio desta instalação ──
APP_NAME=Ibigan
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ibigan.com.br
APP_TIMEZONE=America/Sao_Paulo

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ibigan_central
DB_USERNAME=ibigan
DB_PASSWORD=

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PREFIX=ibigan_

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_BROADCAST_HOST=reverb
REVERB_BROADCAST_PORT=8080
REVERB_BROADCAST_SCHEME=http
REVERB_PUBLIC_HOST=ibigan.com.br
REVERB_PUBLIC_PORT=443
REVERB_PUBLIC_SCHEME=https

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@ibigan.com.br
MAIL_FROM_NAME=Ibigan

SCOUT_DRIVER=meilisearch
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_KEY=

FRONTEND_URL=https://ibigan.com.br
CENTRAL_DOMAIN=ibigan.com.br
TENANT_DEV_DOMAIN_SUFFIXES=ibigan.com.br
TENANT_CONTEXT_QUERY_PARAM=tenant

SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production

# ── Docker Compose (docker-compose.prod.yml) ──
# Com Caddy no host (dois stacks no mesmo VPS): HTTP no nginx interno, TLS no Caddy.
NGINX_BEHIND_PROXY=true

# Stack ÚNICO no VPS (sem Caddy): bind público 80/443 e TLS no nginx.
# NGINX_BEHIND_PROXY=false
# NGINX_HTTP_PORT=80
# NGINX_HTTPS_PORT=443

# Dois stacks no MESMO VPS (Caddy na 80/443):
# NGINX_BEHIND_PROXY=true
# NGINX_HTTP_BIND=127.0.0.1
# NGINX_HTTP_PORT=18080   (ibigan) ou 28080 (nagibi)
# (HTTPS interno não é necessário — ver docker/host-proxy/Caddyfile.example)

MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=ibigan_central
MYSQL_USER=ibigan
MYSQL_PASSWORD=

# ── Dois stacks no mesmo VPS (Caddy na 80/443) ─────────────────
# | Variável              | /opt/nagibi | /opt/ibigan |
# |-----------------------|-------------|-------------|
# | STACK_NAME            | nagibi      | ibigan      |
# | NGINX_BEHIND_PROXY    | true        | true        |
# | NGINX_HTTP_BIND       | 127.0.0.1   | 127.0.0.1   |
# | NGINX_HTTP_PORT       | 28080       | 18080       |
# | MYSQL_HOST_PORT       | 3306        | 3307        |
# | REDIS_PREFIX          | nagibi_     | ibigan_     |
#
# Reverb: nginx interno faz proxy /app/ → reverb:8080
