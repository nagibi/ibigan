# Copiar para /opt/ibigan/.env no servidor (Docker Compose)
# O GitHub Actions NÃO envia este arquivo — crie/edite só no VPS.
# Laravel (APP_KEY, mail, Reverb…) fica em projects/ibigan-api/.env (arquivo separado).
# Não misture variáveis APP_* aqui — use só chaves Docker/MySQL/nginx abaixo.
#
# Obrigatório para ./scripts/deploy-prod.sh:
#   MYSQL_ROOT_PASSWORD, MYSQL_PASSWORD, MYSQL_USER, MYSQL_DATABASE, CENTRAL_DOMAIN

STACK_NAME=ibigan
APP_TIMEZONE=America/Sao_Paulo
CENTRAL_DOMAIN=ibigan.com.br
REDIS_PREFIX=ibigan_

NGINX_BEHIND_PROXY=true
NGINX_HTTP_BIND=127.0.0.1
NGINX_HTTP_PORT=18080
# Não use NGINX_HTTPS_* — TLS no Caddy (host), não no container nginx

# ibigan=3307 no mesmo VPS que nagibi (3306) — ver docker/host-proxy/Caddyfile.example
MYSQL_HOST_PORT=3307
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=ibigan_central
MYSQL_USER=ibigan
MYSQL_PASSWORD=

# Meilisearch — mesmo valor de MEILISEARCH_KEY em projects/ibigan-api/.env
MEILISEARCH_KEY=

# Grafana (opcional)
GRAFANA_PASSWORD=

# ── Laravel: /opt/ibigan/projects/ibigan-api/.env ─────────────
# Ver projects/ibigan-api/.env.production.example
