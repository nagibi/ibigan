# Copiar para /opt/ibigan/.env no servidor (Docker Compose)
# Laravel (APP_KEY, DB_*, mail, Reverb…) fica em projects/ibigan-api/.env

STACK_NAME=ibigan
APP_TIMEZONE=America/Sao_Paulo
CENTRAL_DOMAIN=ibigan.com.br
REDIS_PREFIX=ibigan_

NGINX_BEHIND_PROXY=true
NGINX_HTTP_BIND=127.0.0.1
NGINX_HTTP_PORT=28080

MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=ibigan_central
MYSQL_USER=ibigan
MYSQL_PASSWORD=

# Meilisearch — mesmo valor de MEILISEARCH_KEY em projects/ibigan-api/.env
MEILISEARCH_KEY=

# Grafana (opcional)
GRAFANA_PASSWORD=

# ── Laravel: /opt/ibigan/projects/ibigan-api/.env ─────────────
# Ver projects/ibigan-api/.env.production.example
