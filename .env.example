# ── Docker ────────────────────────────────────────────────────
USER_ID=1000
GROUP_ID=1000
INSTALL_XDEBUG=0

# ── Portas ────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
MYSQL_HOST_PORT=3307
REDIS_HOST_PORT=6379
REVERB_PORT=8082
VITE_PORT=5173
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025
PMA_PORT=8080
GRAFANA_PASSWORD=admin

# Token do /metrics Laravel — deve coincidir com docker/prometheus/prometheus.yml
# METRICS_TOKEN=ibigan_metrics_dev

# ── MySQL ─────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=ibigan_central
MYSQL_USER=dev
MYSQL_PASSWORD=dev

# ════════════════════════════════════════════════════════════════
# Laravel .env — copiar para projects/ibigan-api/.env
# ════════════════════════════════════════════════════════════════
# APP_NAME=Ibigan
# APP_ENV=local
# APP_KEY=
# APP_DEBUG=true
# APP_URL=http://localhost

# DB_CONNECTION=mysql
# DB_HOST=mysql
# DB_PORT=3306
# DB_DATABASE=ibigan_central
# DB_USERNAME=dev
# DB_PASSWORD=dev

# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_CLIENT=phpredis
# REDIS_PREFIX=ibigan_

# CACHE_STORE=redis
# QUEUE_CONNECTION=redis
# SESSION_DRIVER=redis

# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_FROM_ADDRESS="no-reply@ibigan.local"

# REVERB_APP_ID=ibigan
# REVERB_APP_KEY=ibigan_key
# REVERB_APP_SECRET=ibigan_secret
# REVERB_HOST=localhost
# REVERB_PORT=8082
# REVERB_SCHEME=http

# BROADCAST_CONNECTION=reverb

# PROMETHEUS_ENABLED=true
# METRICS_TOKEN=ibigan_metrics_dev

# ════════════════════════════════════════════════════════════════
# React .env — copiar para projects/ibigan-web/.env.local
# ════════════════════════════════════════════════════════════════
# VITE_APP_NAME=Ibigan
# VITE_API_URL=http://localhost/api
# VITE_API_VERSION=v1
# VITE_REVERB_APP_KEY=ibigan_key
# VITE_REVERB_HOST=localhost
# VITE_REVERB_PORT=8082
# VITE_REVERB_SCHEME=http
